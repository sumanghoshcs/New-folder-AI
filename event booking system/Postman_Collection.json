    {
      "name": "Events - Organizer",
      "item": [
        {
          "name": "Create Event",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{ORGANIZER_TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Tech Conference 2024\",\n  \"description\": \"Annual technology conference\",\n  \"date\": \"2024-12-20\",\n  \"location\": \"San Francisco\",\n  \"totalTickets\": 100,\n  \"price\": 99.99\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/events",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "events"]
            },
            "description": "Create a new event (organizer only)"
          },
          "response": []
        },
        {
          "name": "Get Organizer Events",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ORGANIZER_TOKEN}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/events/organizer/list",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "events", "organizer", "list"]
            },
            "description": "Get all events created by organizer"
          },
          "response": []
        },
        {
          "name": "Get Event Details",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ORGANIZER_TOKEN}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/events/{{EVENT_ID}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "events", "{{EVENT_ID}}"]
            },
            "description": "Get details of a specific event"
          },
          "response": []
        },
        {
          "name": "Update Event",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{ORGANIZER_TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"published\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/events/{{EVENT_ID}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "events", "{{EVENT_ID}}"]
            },
            "description": "Update event details (title, description, date, location, totalTickets, price, status)"
          },
          "response": []
        },
        {
          "name": "Update Event - Full Example",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{ORGANIZER_TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Tech Conference 2024 - Updated\",\n  \"description\": \"Annual technology conference - Extended\",\n  \"date\": \"2024-12-21\",\n  \"location\": \"San Francisco, CA\",\n  \"totalTickets\": 150,\n  \"price\": 119.99,\n  \"status\": \"published\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/events/{{EVENT_ID}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "events", "{{EVENT_ID}}"]
            },
            "description": "Update event with all available fields"
          },
          "response": []
        },
        {
          "name": "Delete Event",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ORGANIZER_TOKEN}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/events/{{EVENT_ID}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "events", "{{EVENT_ID}}"]
            },
            "description": "Delete an event (organizer only)"
          },
          "response": []
        }
      ]
    },
